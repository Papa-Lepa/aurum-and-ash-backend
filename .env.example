# Copy this file to .env for local testing with `vercel dev`.
# In production, set these in the Vercel dashboard instead
# (Project → Settings → Environment Variables) — never commit a real .env file.

# Connection string from your Neon project (Vercel Storage tab, or neon.tech directly)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# API key from resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Must be onboarding@resend.dev until you verify your own domain in Resend
ORDER_FROM_EMAIL=onboarding@resend.dev

# Optional: if set, this address gets a "new order" email too
OWNER_EMAIL=you@example.com

# Your frontend's deployed URL, e.g. https://aurum-frontend.vercel.app
# Leave unset while testing (defaults to allowing any origin), but set it
# once you know the real URL, to avoid random sites calling your API.
CORS_ORIGIN=
